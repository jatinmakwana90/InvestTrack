<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:navigationIcon="@drawable/ic_back"
            app:titleTextColor="@color/text_on_primary" />

        <!-- Security + Value Hero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="4dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tv_security_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security Name"
                android:textColor="@color/text_on_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_symbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NSE"
                    android:textColor="#B0BEC5"
                    android:textSize="12sp" />

                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@color/text_hint"
                    android:layout_marginStart="8dp" android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_security_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Equity"
                    android:textColor="#B0BEC5"
                    android:textSize="12sp" />

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_cmp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CMP: ₹0.00"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_folio_no"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B0BEC5"
                android:textSize="11sp"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_current_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textColor="@color/text_on_primary"
                android:textSize="30sp"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_invested"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Invested: ₹0.00"
                    android:textColor="#B0BEC5"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_p_n_l"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+₹0 (0.00%)"
                    android:textColor="@color/gain_green"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_item"
                    android:padding="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Units / Qty" android:textColor="#B0BEC5" android:textSize="11sp" />
                    <TextView android:id="@+id/tv_units" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0.000" android:textColor="@color/text_on_primary" android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_item"
                    android:padding="10dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Avg Buy Price" android:textColor="#B0BEC5" android:textSize="11sp" />
                    <TextView android:id="@+id/tv_avg_cost" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹0.00" android:textColor="@color/text_on_primary" android:textSize="15sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Transactions header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Transactions"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_txn_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Transactions"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_transactions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="12dp"
        android:paddingBottom="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
